# =============================================================
# SECRETS & CREDENTIALS  ← NEVER commit these!
# =============================================================
# Environment variables (real values live here, never committed)
.env
.env.*
!.env.example          # Keep the TEMPLATE, ignore real values

# AWS credentials & config (stored by AWS CLI in ~/.aws — not here)
.aws/
aws-credentials
*.pem
*.key
*_rsa
*_rsa.pub
*.ppk

# Any file named "secrets" regardless of extension
secrets.*
*secrets*
*password*
*credentials*

# =============================================================
# TERRAFORM
# =============================================================
# Local .terraform plugin cache (downloaded by `terraform init`)
.terraform/
.terraform.lock.hcl   # Uncomment to commit lock file (recommended for teams)
# !.terraform.lock.hcl  # <- uncomment this line to TRACK the lock file

# State files — contain real infrastructure IDs, sometimes secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files — often contain secrets (access keys, passwords)
*.tfvars
*.tfvars.json
# EXCEPTION: commit example tfvars so teammates know what vars are needed
!*.tfvars.example

# Override files (local dev overrides, not for team use)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock info file created during `terraform apply`
.terraform.tfstate.lock.info

# Plan output files (binary, machine-generated)
*.tfplan
tfplan

# Terraform CLI config
.terraformrc
terraform.rc

# =============================================================
# JENKINS
# =============================================================
# Jenkins home dir if run locally
.jenkins/
jenkins_home/

# =============================================================
# OPERATING SYSTEM FILES
# =============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================
# IDE & EDITOR FILES
# =============================================================
# VSCode
.vscode/
!.vscode/extensions.json   # Keep recommended extensions list

# IntelliJ / JetBrains
.idea/
*.iml

# Vim/Neovim
*.swp
*.swo

# =============================================================
# LANGUAGE / BUILD ARTIFACTS
# =============================================================
# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node.js
node_modules/
npm-debug.log*

# General build output
dist/
build/
*.log